# Supabase Postgres connection (Transaction pooler — port 6543)
# Get these from: Supabase Dashboard → Project Settings → Database
PGHOST=aws-1-<region>.pooler.supabase.com
PGPORT=6543
PGUSER=postgres.<project-ref>
PGPASSWORD=<your-db-password>
PGDATABASE=postgres

# Alternatively, use a single URL (remember to URL-encode special chars in password):
# DATABASE_URL=postgresql://postgres.<ref>:<encoded-pass>@aws-1-<region>.pooler.supabase.com:6543/postgres
